# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/whatsapp_appointments"

# WhatsApp — número Ovapy (el tuyo, plataforma)
# Token Bearer del número Ovapy
WHATSAPP_TOKEN="your_ovapy_bearer_token"
# phone_number_id del número Ovapy en Meta
OVAPY_PHONE_NUMBER_ID="phone_number_id_del_numero_ovapy"
# Verify token para el webhook (puede ser el mismo para todos los números si usan la misma app)
WHATSAPP_VERIFY_TOKEN="tu_verify_token_secreto"

# Las credenciales del número de cada cliente (negocio) se configuran
# desde el panel admin: PATCH /admin/business/config
# (waToken, waPhoneNumberId, waVerifyToken)

# OpenAI
OPENAI_API_KEY="sk-..."

# Admin panel API key — required to access /admin/* endpoints
ADMIN_API_KEY="clave-secreta-panel-admin"

# App port
PORT=3000

# Google Sheets integration (service account)
GOOGLE_SHEETS_SPREADSHEET_ID="ID del spreadsheet (de la URL)"
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@project.iam.gserviceaccount.com",...}'
